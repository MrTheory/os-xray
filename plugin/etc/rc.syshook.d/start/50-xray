#!/bin/sh

LOG="/tmp/xray_syshook.log"
LOG_MAX=50000   # ~50 KB — максимальный размер лога перед ротацией (B11)

# B11: ротация лога
if [ -f "$LOG" ]; then
    _size=$(wc -c < "$LOG" 2>/dev/null || echo 0)
    if [ "$_size" -gt "$LOG_MAX" ]; then
        mv -f "$LOG" "${LOG}.0"
    fi
fi

exec >> "$LOG" 2>&1
echo ""
echo "=== xray syshook start: $(date) ==="

XRAY_BIN="/usr/local/bin/xray-core"
T2S_BIN="/usr/local/tun2socks/tun2socks"

# v3.0.0: первый аргумент — inst_uuid конкретного инстанса (опционально)
# Если не задан — обрабатываем все инстансы из config.xml
INST_UUID="${1:-}"

ENABLED=$(php -r 'set_include_path("/usr/local/etc/inc" . PATH_SEPARATOR . get_include_path()); require_once("config.inc"); $cfg = OPNsense\Core\Config::getInstance()->object(); echo (string)($cfg->OPNsense->xray->general->enabled ?? "0");' 2>/dev/null)

echo "enabled=[$ENABLED] inst_uuid=[$INST_UUID]"

[ "$ENABLED" = "1" ] || { echo "xray disabled, exit"; exit 0; }
[ -f "$XRAY_BIN" ]   || { echo "xray-core not found"; exit 0; }
[ -f "$T2S_BIN" ]    || { echo "tun2socks not found"; exit 0; }

# Функция: настроить TUN для одного инстанса
setup_instance() {
    _INST_UUID="$1"

    # BUG-8 FIX: ожидаем per-instance lock
    _XRAY_LOCK="/var/run/xray_start_${_INST_UUID}.lock"
    _lock_tries=0
    while [ -f "$_XRAY_LOCK" ] && [ $_lock_tries -lt 10 ]; do
        echo "  [${_INST_UUID}] waiting for lock (${_lock_tries}s)..."
        sleep 1
        _lock_tries=$((_lock_tries+1))
    done

    # BUG-2 FIX: TUN_IFACE передаётся через env, не через shell interpolation
    _INST_UUID="$_INST_UUID" TUN_IFACE=$(php -r '
        set_include_path("/usr/local/etc/inc" . PATH_SEPARATOR . get_include_path());
        require_once("config.inc");
        $cfg = OPNsense\Core\Config::getInstance()->object();
        $uuid = getenv("_INST_UUID");
        foreach ($cfg->OPNsense->xray->instances->instance as $inst) {
            if ((string)$inst["uuid"] === $uuid) {
                echo (string)($inst->tun_interface ?? "proxytun2socks0");
                exit(0);
            }
        }
        echo "proxytun2socks0";
    ' 2>/dev/null)

    _INST_UUID="$_INST_UUID" MTU=$(php -r '
        set_include_path("/usr/local/etc/inc" . PATH_SEPARATOR . get_include_path());
        require_once("config.inc");
        $cfg = OPNsense\Core\Config::getInstance()->object();
        $uuid = getenv("_INST_UUID");
        foreach ($cfg->OPNsense->xray->instances->instance as $inst) {
            if ((string)$inst["uuid"] === $uuid) {
                echo (string)($inst->mtu ?? "1500");
                exit(0);
            }
        }
        echo "1500";
    ' 2>/dev/null)

    TUN_IFACE="${TUN_IFACE:-proxytun2socks0}"
    MTU="${MTU:-1500}"

    echo "[${_INST_UUID}] tun=[$TUN_IFACE] mtu=[$MTU]"

    # Ждём TUN интерфейс до 10 секунд
    echo "waiting for $TUN_IFACE..."
    i=0
    while [ $i -lt 10 ]; do
        ifconfig "$TUN_IFACE" > /dev/null 2>&1 && break
        sleep 1
        i=$((i+1))
        echo "  ${i}s..."
    done

    ifconfig "$TUN_IFACE" > /dev/null 2>&1 || { echo "[${_INST_UUID}] interface $TUN_IFACE not found after 10s!"; return 0; }

    # Поднимаем интерфейс и назначаем MTU
    ifconfig "$TUN_IFACE" mtu "$MTU" up 2>&1

    # Назначаем IP из OPNsense interfaces (BUG-2 FIX: через env)
    _TUN_IFACE="$TUN_IFACE" TUN_IP=$(php -r '
        set_include_path("/usr/local/etc/inc" . PATH_SEPARATOR . get_include_path());
        require_once("config.inc");
        $cfg = OPNsense\Core\Config::getInstance()->object();
        $tun = getenv("_TUN_IFACE");
        if (empty($tun)) $tun = "proxytun2socks0";
        foreach ($cfg->interfaces->children() as $iface) {
            if ((string)$iface->if === $tun) {
                echo (string)$iface->ipaddr . "/" . (string)$iface->subnet;
                break;
            }
        }
    ' 2>/dev/null)

    if [ -n "$TUN_IP" ]; then
        echo "[${_INST_UUID}] assigning $TUN_IP to $TUN_IFACE..."
        ifconfig "$TUN_IFACE" inet "$TUN_IP" 2>&1
    else
        echo "[${_INST_UUID}] WARNING: no IP found in config, skipping IP assignment"
    fi
}

if [ -n "$INST_UUID" ]; then
    # Обрабатываем конкретный инстанс
    setup_instance "$INST_UUID"
else
    # Обрабатываем все инстансы
    INST_UUIDS=$(php -r '
        set_include_path("/usr/local/etc/inc" . PATH_SEPARATOR . get_include_path());
        require_once("config.inc");
        $cfg = OPNsense\Core\Config::getInstance()->object();
        $instances = $cfg->OPNsense->xray->instances ?? null;
        if ($instances) {
            foreach ($instances->instance as $inst) {
                $uuid = (string)$inst["uuid"];
                if ($uuid !== "") echo $uuid . "\n";
            }
        }
    ' 2>/dev/null)

    for uuid in $INST_UUIDS; do
        setup_instance "$uuid"
    done
fi

echo "reloading filter..."
/usr/local/sbin/configctl filter reload 2>&1

echo "reconfiguring interfaces..."
/usr/local/sbin/configctl interface reconfigure 2>&1

echo "=== done: $(date) ==="
exit 0
